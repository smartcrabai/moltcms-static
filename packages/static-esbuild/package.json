{
	"name": "@moltcms/static-esbuild",
	"version": "0.1.0",
	"description": "esbuild browser asset and server-module graph adapter for moltcms static sites.",
	"license": "Apache-2.0",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"prepublishOnly": "bun run build"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/smartcrabai/moltcms-static.git"
	},
	"keywords": [
		"moltcms",
		"esbuild",
		"assets",
		"static-site-generator"
	],
	"engines": {
		"node": ">=22"
	},
	"dependencies": {
		"@moltcms/static-core": "^0.1.0",
		"esbuild": "^0.27.3"
	}
}
