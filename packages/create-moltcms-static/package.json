{
	"name": "create-moltcms-static",
	"version": "0.1.1",
	"description": "Create a MoltCMS static site.",
	"license": "Apache-2.0",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"bin": {
		"create-moltcms-static": "./dist/cli.js"
	},
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"check": "tsc -p ../../tsconfig.json --noEmit",
		"test": "bun run build && bun test src",
		"prepublishOnly": "bun run build"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/smartcrabai/moltcms-static.git"
	},
	"keywords": [
		"moltcms",
		"create",
		"static-site-generator"
	],
	"engines": {
		"bun": ">=1.3.0"
	}
}
